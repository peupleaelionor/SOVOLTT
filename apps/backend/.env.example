# Base de données PostgreSQL
DATABASE_URL="postgresql://user:password@localhost:5432/sovoltt?schema=public"

# JWT
JWT_SECRET="votre-secret-jwt-tres-securise"
JWT_EXPIRATION="7d"

# Stripe Connect
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PLATFORM_FEE_PERCENT=5

# API Enedis (SGE)
ENEDIS_CLIENT_ID="votre-client-id-enedis"
ENEDIS_CLIENT_SECRET="votre-client-secret-enedis"
ENEDIS_API_URL="https://ext.hml.api.enedis.fr"
ENEDIS_REDIRECT_URI="https://api.sovoltt.fr/enedis/callback"

# Serveur
PORT=3000
NODE_ENV=development

# Expo Push Notifications
EXPO_ACCESS_TOKEN="votre-token-expo"

# CORS
CORS_ORIGIN="http://localhost:19006"
